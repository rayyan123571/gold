{
  "name": "gold-ledger",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "tsc -p tsconfig.electron.json && vite build && electron-builder",
    "electron:preview": "tsc -p tsconfig.electron.json && vite build && electron ."
  },
  "build": {
    "appId": "com.sonahisaab.gold-ledger",
    "productName": "Sona Hisaab",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "electronDist": "node_modules/electron/dist",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sona Hisaab",
      "uninstallDisplayName": "Sona Hisaab - Gold Ledger"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dexie": "^4.4.3",
    "i18next": "^26.3.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-is": "^19.0.0",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-rtl": "^0.9.0",
    "vite-plugin-pwa": "^1.3.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
    ,"bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^1.0.3",
    "vite-plugin-electron-renderer": "^1.0.0"
  }
}
